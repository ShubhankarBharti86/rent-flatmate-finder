# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Database (Postgres). For local dev without Postgres, see README "Local Dev with SQLite".
DATABASE_URL="postgresql://user:password@localhost:5432/rent_flatmate_finder?schema=public"

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# LLM (Anthropic). If omitted or the call fails, the app falls back to rule-based scoring.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Compatibility score threshold above which the owner gets a "high match" email
HIGH_MATCH_THRESHOLD=80

# Email (any free-tier SMTP works, e.g. Gmail App Password, Mailtrap, Brevo/Sendinblue, Resend SMTP)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Rent & Flatmate Finder <no-reply@rentfinder.test>"
